# ── Jim Bot — Kraken Futures (GEO strategy) ──────────────────────────────────
# Copie ce fichier vers .env puis remplis tes clés.
#   cp .env.example .env && chmod 600 .env

# Broker actif (kraken | bybit | alpaca)
ACTIVE_BROKER=kraken

# ── Kraken Futures ────────────────────────────────────────────────────────────
# Clés API — génère-les sur https://futures.kraken.com (Settings → API Keys)
# Permissions requises : General info + Full access (trading) sur Futures
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# 1 = démo (demo-futures.kraken.com), 0 = LIVE (futures.kraken.com)
# ⚠️  Reste à 1 tant que tu n'as pas validé quelques cycles en paper.
KRAKEN_PAPER=1

# ── Capital alloué à la stratégie GEO (USD) ──────────────────────────────────
INITIAL_CAPITAL=100

# ── Dashboard Flask ──────────────────────────────────────────────────────────
PORT=5000
